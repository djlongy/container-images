# Local environment overrides (copy from *.example on first clone).
# Global config: PULL/PUSH registries, mirror URLs, team/vendor strings.
global.env

# Per-image local overrides. Templates live in images/<name>/image.env.example
# (versioned); the real image.env is gitignored so teams can pin different
# TAGs, flip INJECT_CERTS, etc. without committing local state.
images/*/image.env

# CA certificates — injected at build time from CI variables or Vault
# Never commit certs to the repo (may be pushed to public GitHub)
certs/*.crt
certs/*.pem
certs/*.srl
certs/*.key
certs/*.csr
!certs/.gitkeep

# Vault / credentials — never committed
.vault-token
credentials*.env

# Agent / editor runtime state
.claude/
.playwright-mcp/
build.env

# SonarQube scanner output
.scannerwork/

# Local workspace — test runners, credential exports, scratch
# playbooks, and any other files that reference real hostnames,
# team names, tokens, or other environment-specific values that
# should never land in the public template. Keep anything you
# don't want sanitized under local/ and it stays on your machine.
local/

# Internal design notes / hand-off docs — kept on-disk, not shipped
docs/

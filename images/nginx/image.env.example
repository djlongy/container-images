# Nginx — https://hub.docker.com/_/nginx

# ── Required: pull and build ──────────────────────────────────────────
IMAGE_NAME="nginx"
TAG="1.29.8-alpine"
DISTRO="alpine"
SOURCE="${DOCKERHUB_MIRROR}/library/nginx"

# ── Optional: registry destination ───────────────────────────────────
# Override the global PUSH_PROJECT to push to a different path.
# If not set, uses the default from global.env (e.g. base-images).
# PUSH_PROJECT="myproject"    # → ${PUSH_REGISTRY}/myproject/nginx

# ── Optional: custom labels ──────────────────────────────────────────
# One label per line in labels.env (key=value format).
# LABELS file: images/nginx/labels.env

# ── Optional: enrichment ─────────────────────────────────────────────
REMEDIATE="true"
# Upstream nginx image ships with User="" — /docker-entrypoint.sh needs
# to run as root so it can chown, run envsubst, write /var/run/nginx.pid,
# etc., and nginx itself drops to the `nginx` user via its own daemon
# config. Setting USER nginx here breaks the entrypoint.
ORIGINAL_USER="root"
INJECT_CERTS="false"

# Note: bumped 2026-04-14 via GitLab pipeline test.

# Nginx — https://hub.docker.com/_/nginx
#
# Variable naming matches the container-image-template repo:
#   UPSTREAM_REGISTRY + UPSTREAM_IMAGE + UPSTREAM_TAG

# ── Required: upstream source ────────────────────────────────────────
IMAGE_NAME="nginx"
UPSTREAM_REGISTRY="${DOCKERHUB_MIRROR}/library"
UPSTREAM_IMAGE="nginx"
# renovate: datasource=docker depName=library/nginx
UPSTREAM_TAG="1.29.8-alpine"
DISTRO="alpine"

# ── Optional: registry destination ───────────────────────────────────
# Override the global PUSH_PROJECT to push to a different path.
# PUSH_PROJECT="myproject"    # → ${PUSH_REGISTRY}/myproject/nginx

# ── Optional: enrichment ─────────────────────────────────────────────
REMEDIATE="true"
ORIGINAL_USER="root"
INJECT_CERTS="false"

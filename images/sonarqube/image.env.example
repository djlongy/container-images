# SonarQube Community — https://hub.docker.com/_/sonarqube
#
# Upstream base: ubuntu:24.04 (Noble) via eclipse-temurin:21-jre
# Runtime user: sonarqube (uid 1000, gid 0)

# ── Required: pull and build ──────────────────────────────────────────
IMAGE_NAME="sonarqube"
TAG="26.4.0.121862-community"
DISTRO="ubuntu"
SOURCE="${DOCKERHUB_MIRROR}/library/sonarqube"

# ── Optional: registry destination ───────────────────────────────────
# PUSH_PROJECT="myproject"    # → ${PUSH_REGISTRY}/myproject/sonarqube

# ── Optional: custom labels ──────────────────────────────────────────
# LABELS file: images/sonarqube/labels.env

# ── Optional: enrichment ─────────────────────────────────────────────
# Remediation runs apt-get --only-upgrade upgrade via scripts/remediate/ubuntu.sh.
# Requires outbound access to Ubuntu archives (or an apt mirror). Flip to
# "false" if this image is built in a network that can't reach archive.ubuntu.com.
REMEDIATE="true"
INJECT_CERTS="true"
ORIGINAL_USER="sonarqube"

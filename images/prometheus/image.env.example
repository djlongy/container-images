# Prometheus — https://github.com/prometheus/prometheus

# ── Required: pull and build ──────────────────────────────────────────
IMAGE_NAME="prometheus"
# renovate: datasource=docker depName=prom/prometheus
TAG="v3.11.2"
DISTRO="busybox"
SOURCE="${PULL_REGISTRY}/docker-hub/prom/prometheus"

# ── Optional: registry destination ───────────────────────────────────
# Override the global PUSH_PROJECT to push to a different path.
# If not set, uses the default from global.env (e.g. base-images).
# PUSH_PROJECT="myproject"    # → ${PUSH_REGISTRY}/myproject/prometheus

# ── Optional: custom labels ──────────────────────────────────────────
# One label per line in labels.env (key=value format).
# LABELS file: images/prometheus/labels.env

# ── Optional: enrichment ─────────────────────────────────────────────
# NOTE: prom/prometheus is a busybox-based scratch image — no package
# manager. REMEDIATE must stay false; upstream patches via version bumps.
REMEDIATE="false"
INJECT_CERTS="true"
ORIGINAL_USER="nobody"

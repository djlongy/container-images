# Prometheus — https://github.com/prometheus/prometheus
#
# Variable naming matches the container-image-template repo:
#   UPSTREAM_REGISTRY + UPSTREAM_IMAGE + UPSTREAM_TAG

# ── Required: upstream source ────────────────────────────────────────
IMAGE_NAME="prometheus"
UPSTREAM_REGISTRY="${DOCKERHUB_MIRROR}/prom"
UPSTREAM_IMAGE="prometheus"
# renovate: datasource=docker depName=prom/prometheus
UPSTREAM_TAG="v3.11.2"
DISTRO="busybox"

# ── Optional: enrichment ─────────────────────────────────────────────
# NOTE: prom/prometheus is a busybox-based scratch image — no package
# manager. REMEDIATE must stay false; upstream patches via version bumps.
REMEDIATE="false"
INJECT_CERTS="true"
ORIGINAL_USER="nobody"

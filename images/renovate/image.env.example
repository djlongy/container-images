# Renovate — https://hub.docker.com/r/renovate/renovate

# ── Required: upstream source ────────────────────────────────────────
IMAGE_NAME="renovate"
UPSTREAM_REGISTRY="${DOCKERHUB_MIRROR}/renovate"
UPSTREAM_IMAGE="renovate"
# renovate: datasource=docker depName=renovate/renovate
UPSTREAM_TAG="43.127.0"
DISTRO="ubuntu"

# ── Optional: enrichment ─────────────────────────────────────────────
REMEDIATE="true"
INJECT_CERTS="false"
ORIGINAL_USER="12021"
